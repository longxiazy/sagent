# ─── API Keys ──────────────────────────────────────────────
# 至少填一个，填哪些用哪些模型
NVIDIA_API_KEY=nvapi-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Server ───────────────────────────────────────────────
PORT=3001

# ─── Models ───────────────────────────────────────────────
# 可选模型（逗号分隔）：
#   NVIDIA:  minimaxai/minimax-m2.7, meta/llama-3.3-70b-instruct,
#            moonshotai/kimi-k2.5, google/gemma-4-31b-it,
#            nvidia/nemotron-3-super-120b-a12b, qwen/qwen3.5-397b-a17b,
#            z-ai/glm-5.1, deepseek-ai/deepseek-v4-pro
#   Claude:  claude-opus-4-7, claude-sonnet-4-6, claude-haiku-4-5
# 留空则默认只用 minimaxai/minimax-m2.7
MODELS=minimaxai/minimax-m2.7,moonshotai/kimi-k2.5,qwen/qwen3.5-397b-a17b

# Agent 竞速模式：每步并发发给多个模型，最先返回的结果胜出
# 留空则禁用竞速
AGENT_MULTI_MODELS=moonshotai/kimi-k2.5,qwen/qwen3.5-397b-a17b

# ─── Agent ────────────────────────────────────────────────
AGENT_MAX_STEPS=32
AGENT_HEADLESS=false
AGENT_BROWSER_PATH=

# ─── Logging ──────────────────────────────────────────────
# debug | info (default) | warn | error
LOG_LEVEL=info
