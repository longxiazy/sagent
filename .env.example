# ─── API Keys ──────────────────────────────────────────────
# 至少填一个，填哪些用哪些模型
NVIDIA_API_KEY=nvapi-...

# ─── Server ───────────────────────────────────────────────
PORT=3001

# ─── Models ───────────────────────────────────────────────
# 可选模型（逗号分隔）：
#   NVIDIA:  minimaxai/minimax-m2.7, meta/llama-3.3-70b-instruct,
#            moonshotai/kimi-k2.5, google/gemma-4-31b-it,
#            nvidia/nemotron-3-super-120b-a12b, qwen/qwen3.5-397b-a17b,
#            z-ai/glm-5.1, deepseek-ai/deepseek-v4-pro
MODELS=minimaxai/minimax-m2.7,moonshotai/kimi-k2.5,nvidia/nemotron-3-super-120b-a12b,qwen/qwen3.5-397b-a17b,z-ai/glm-5.1,deepseek-ai/deepseek-v4-pro

# ─── Agent ────────────────────────────────────────────────
AGENT_MAX_STEPS=32
AGENT_HEADLESS=false
AGENT_BROWSER_PATH=
AGENT_RESUME=true

# ─── Optional ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Logging ──────────────────────────────────────────────
# debug | info (default) | warn | error
LOG_LEVEL=info
