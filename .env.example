# ─── API Keys ──────────────────────────────────────────────
# 至少填一个，填哪些用哪些模型
NVIDIA_API_KEY=nvapi-...
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=                          # 自定义 Anthropic 端点（如 https://open.bigmodel.cn/api/anthropic）

# ─── Server ───────────────────────────────────────────────
PORT=3001

# ─── Models ───────────────────────────────────────────────
# 逗号分隔，不填则根据 API Key 自动选择默认模型
#   NVIDIA:   minimaxai/minimax-m2.7, meta/llama-3.3-70b-instruct,
#             moonshotai/kimi-k2.5, google/gemma-4-31b-it,
#             nvidia/nemotron-3-super-120b-a12b, qwen/qwen3.5-397b-a17b,
#             z-ai/glm-5.1, deepseek-ai/deepseek-v4-pro
#   Anthropic: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5
#   第三方 Anthropic 兼容: glm-5.1 等（需配合 ANTHROPIC_BASE_URL）
# MODELS=minimaxai/minimax-m2.7,claude-sonnet-4-6

# ─── Agent ────────────────────────────────────────────────
AGENT_MAX_STEPS=32
AGENT_HEADLESS=false
AGENT_BROWSER_PATH=
AGENT_RESUME=false

# ─── Agent Multi-Model ───────────────────────────────────
# Agent 每步并发请求多个模型，取最快结果（逗号分隔）
# AGENT_MULTI_MODELS=moonshotai/kimi-k2.5,qwen/qwen3.5-397b-a17b

# ─── Logging ──────────────────────────────────────────────
# debug | info (default) | warn | error
LOG_LEVEL=info
